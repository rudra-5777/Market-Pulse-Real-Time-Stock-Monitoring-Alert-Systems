# ─────────────────────────────────────────────────────────────────────────────
# MarketPulse – Environment Variables
# Copy this file to .env.local (never commit .env.local to source control).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-public-key

# ── Alpha Vantage ─────────────────────────────────────────────────────────────
# Free tier: 5 API requests / minute, 500 / day
# Get a free key at: https://www.alphavantage.co/support/#api-key
# NOTE: On the free tier the Edge Function will automatically queue requests
#       so that no more than 5 are sent per 60-second window.
REACT_APP_ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# ── Supabase Edge Function (server-side only) ─────────────────────────────────
# Set these in: Supabase Dashboard → Edge Functions → Environment Variables
# They are NOT exposed to the browser.
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
